#!/bin/bash
# Neural Music Conductor - One command to start everything
#
# Usage:
#   ./scripts/conductor          # Start full stack (LLM mode)
#   ./scripts/conductor --tui    # Just the TUI (assumes Chrome/DB running)
#   ./scripts/conductor --simple # Use rule-based mode instead of LLM
#   ./scripts/conductor --stop   # Stop everything

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
DB_URL="postgresql://eeg:eegpass@localhost:5590/eeg"

# LLM mode by default
LLM_CONDUCTOR="${LLM_CONDUCTOR:-1}"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log() { echo -e "${GREEN}[conductor]${NC} $1"; }
warn() { echo -e "${YELLOW}[conductor]${NC} $1"; }

# Check if database is running
db_running() {
    docker compose -f "$PROJECT_DIR/docker/compose.yml" ps db 2>/dev/null | grep -q "running"
}

# Check if Chrome is running on CDP port
chrome_running() {
    powershell.exe -Command "Get-Process chrome -ErrorAction SilentlyContinue | Where-Object { \$_.CommandLine -match '9223' }" 2>/dev/null | grep -q "chrome"
}

start_db() {
    if db_running; then
        log "Database already running"
    else
        log "Starting database..."
        docker compose -f "$PROJECT_DIR/docker/compose.yml" up -d db
        sleep 2
    fi
}

start_chrome() {
    log "Launching Chrome with Strudel..."
    powershell.exe -Command "cd C:\projects\prompt-kit\chrome-automation; node scripts/chrome-launcher.mjs --profile=default 'https://strudel.cc'" &
    sleep 3
}

start_tui() {
    if [ "$LLM_CONDUCTOR" = "1" ]; then
        log "Starting Conductor TUI (LLM Mode)..."
    else
        log "Starting Conductor TUI (Rule-based Mode)..."
    fi
    echo ""
    DATABASE_URL="$DB_URL" LLM_CONDUCTOR="$LLM_CONDUCTOR" uv run python "$SCRIPT_DIR/conductor_tui.py"
}

stop_all() {
    log "Stopping conductor..."

    # Kill Chrome Strudel instance
    powershell.exe -Command "cd C:\projects\prompt-kit\chrome-automation; node scripts/chrome-kill.mjs --profile=default" 2>/dev/null || true

    # Stop database
    docker compose -f "$PROJECT_DIR/docker/compose.yml" down 2>/dev/null || true

    log "Stopped"
}

show_help() {
    echo "Neural Music Conductor"
    echo ""
    echo "Usage: ./scripts/conductor [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  (none)      Start full stack with LLM mode (db + chrome + tui)"
    echo "  --tui       Just start TUI (assumes db/chrome running)"
    echo "  --simple    Use rule-based mode instead of LLM"
    echo "  --stop      Stop everything"
    echo "  --help      Show this help"
    echo ""
    echo "Controls (in TUI):"
    echo "  Space       Pause/resume"
    echo "  N           Next pattern"
    echo "  R           Regenerate"
    echo "  Enter       Queue message"
    echo "  Ctrl+Enter  Send immediately"
    echo "  Q           Quit"
    echo ""
    echo "Reasoning log: logs/conductor_reasoning.log"
}

case "${1:-}" in
    --tui)
        start_tui
        ;;
    --simple)
        LLM_CONDUCTOR=0
        log "Starting Neural Music Conductor (Rule-based)..."
        start_db
        start_chrome
        start_tui
        ;;
    --stop)
        stop_all
        ;;
    --help|-h)
        show_help
        ;;
    "")
        log "Starting Neural Music Conductor (LLM Mode)..."
        start_db
        start_chrome
        start_tui
        ;;
    *)
        warn "Unknown option: $1"
        show_help
        exit 1
        ;;
esac
